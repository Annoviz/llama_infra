# Target the superior Unsloth Dynamic file
#FROM hf.co/unsloth/Qwen3-Coder-30B-A3B-Instruct-GGUF:Q6_K
#FROM hf.co/unsloth/Qwen3-Coder-Next-GGUF:Qwen3-Coder-Next-UD-Q4_K_M.gguf
#FROM hf.co/unsloth/Qwen3-Coder-Next-GGUF:Qwen3-Coder-Next-UD-Q4_K_S.gguf
FROM hf.co/unsloth/Qwen3-Coder-Next-GGUF:Qwen3-Coder-Next-UD-IQ4_NL.gguf
#FROM deepseek-coder-v2:16b-lite-instruct-q8_0
# Workstation Core Isolation (Dual Xeon + RTX 6000 Ada)
PARAMETER num_gpu 99
PARAMETER num_ctx 131072
#PARAMETER num_ctx 65536
#PARAMETER num_ctx 32768
#PARAMETER num_ctx 16384
PARAMETER num_thread 16

# Precision Coding Inference Settings
PARAMETER temperature 0.2
PARAMETER top_p 0.85
PARAMETER top_k 20
PARAMETER repeat_penalty 1.05

# Lower the penalty parameters to prevent malformed formatting structures
PARAMETER presence_penalty 0.0
PARAMETER frequency_penalty 0.0

